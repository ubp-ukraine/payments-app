# Скопіюй у .env і підстав значення нового Supabase-інстансу.
#
# Новий self-hosted Supabase на окремому api-домені.
# URL — публічний домен API (без слеша в кінці), напр. https://api.oplaty.example.com
# Ключ — anon / Publishable ключ інстансу (на VM: npx supabase status → anon / Publishable).
VITE_SUPABASE_URL=https://api.oplaty.example.com
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# --- Локальна розробка (supabase start на цьому ж ПК) ---
# Порт Kong цього проєкту — 48000 (не дефолтний 54321), див. supabase/config.toml.
# VITE_SUPABASE_URL=http://127.0.0.1:48000
# VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxx

# --- Хмарний проєкт (Supabase Dashboard → Settings → API), якщо колись знадобиться ---
# VITE_SUPABASE_URL=https://xxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
